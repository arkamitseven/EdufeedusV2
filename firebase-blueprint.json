{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "staff", "admin"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Admission": {
      "title": "Admission",
      "description": "Student admission application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "course": { "type": "string" },
        "address": { "type": "string" },
        "documents": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "verified", "confirmed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "course", "status"]
    },
    "CourseMaterial": {
      "title": "Course Material",
      "description": "Educational material shared with students",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fileUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "video", "notes"] },
        "courseId": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "fileUrl", "type"]
    },
    "MockTest": {
      "title": "Mock Test",
      "description": "Mock test definition",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "courseId": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "courseId", "durationMinutes"]
    },
    "TestResult": {
      "title": "Test Result",
      "description": "Results of a mock test",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "testId": { "type": "string" },
        "score": { "type": "number" },
        "totalMarks": { "type": "number" },
        "attemptedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "testId", "score"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Student attendance record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent"] },
        "batch": { "type": "string" }
      },
      "required": ["studentId", "date", "status"]
    },
    "TeacherResult": {
      "title": "Teacher Result",
      "description": "Results record uploaded by teacher",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "marks": { "type": "number" },
        "subject": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "marks", "subject"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Important announcements for students",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/admissions/{admissionId}": {
      "schema": "Admission",
      "description": "Admission applications"
    },
    "/materials/{materialId}": {
      "schema": "CourseMaterial",
      "description": "LMS materials"
    },
    "/mockTests/{testId}": {
      "schema": "MockTest",
      "description": "Mock tests"
    },
    "/testResults/{resultId}": {
      "schema": "TestResult",
      "description": "Test results"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/teacherResults/{resultId}": {
      "schema": "TeacherResult",
      "description": "Results uploaded by teachers"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Announcements"
    }
  }
}
